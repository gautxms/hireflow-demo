PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/hireflow
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

# AWS S3 upload storage (required for chunk uploads)
AWS_REGION=us-east-1
AWS_S3_BUCKET=hireflow-resume-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Public backend URL used to build verification links in emails.
# Example: https://api.hireflow.dev
BACKEND_PUBLIC_URL=

# Frontend URL to redirect to after successful email verification.
# Example: https://hireflow.dev/verify-email/success
EMAIL_VERIFICATION_SUCCESS_URL=

# SMTP configuration for sending verification emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HireFlow <no-reply@hireflow.dev>"
EMAIL_FROM="HireFlow <gautam@hireflow.dev>"
REPLY_TO_EMAIL=gautam@hireflow.dev

# Paddle payment configuration
PADDLE_ENVIRONMENT=production
PADDLE_API_VERSION=1
PADDLE_PRODUCTION_API_BASE_URL=https://api.paddle.com
PADDLE_PRODUCTION_API_KEY=
PADDLE_PRODUCTION_CLIENT_TOKEN=
PADDLE_PRODUCTION_WEBHOOK_SECRET=
PADDLE_PRODUCTION_MONTHLY_PRICE_ID=
PADDLE_PRODUCTION_ANNUAL_PRICE_ID=

# Backward-compatible production aliases (optional legacy names)
PADDLE_API_KEY=
PADDLE_API_BASE_URL=https://api.paddle.com
PADDLE_WEBHOOK_SECRET=
PADDLE_MONTHLY_PRICE_ID=
PADDLE_ANNUAL_PRICE_ID=

# Checkout success/cancel redirects
APP_ORIGIN=
ADMIN_IP_WHITELIST=0.0.0.0/0

# Claude resume analysis
ANTHROPIC_API_KEY=
ANTHROPIC_RESUME_MODEL=claude-3-5-sonnet-20241022

# Paddle sandbox configuration (used only when PADDLE_ENVIRONMENT=sandbox)
PADDLE_SANDBOX_API_BASE_URL=https://sandbox-api.paddle.com
PADDLE_SANDBOX_API_KEY=
PADDLE_SANDBOX_CLIENT_TOKEN=
PADDLE_SANDBOX_WEBHOOK_SECRET=
PADDLE_SANDBOX_MONTHLY_PRICE_ID=
PADDLE_SANDBOX_ANNUAL_PRICE_ID=


# Email provider selection
EMAIL_PROVIDER=ses
AWS_SES_REGION=ap-south-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
EMAIL_FROM="HireFlow <gautam@hireflow.dev>"
REPLY_TO_EMAIL=gautam@hireflow.dev
