# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hireflow

# Backend Server
BACKEND_PUBLIC_URL=http://localhost:4000
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

# AWS S3 upload storage (required for chunk uploads)
AWS_REGION=us-east-1
AWS_S3_BUCKET=hireflow-resume-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Paddle Payment Gateway
PADDLE_ENVIRONMENT=production
PADDLE_PRODUCTION_API_BASE_URL=https://api.paddle.com
PADDLE_PRODUCTION_API_KEY=pdl_live_xxxxx
PADDLE_PRODUCTION_CLIENT_TOKEN=live_xxxxx
PADDLE_PRODUCTION_WEBHOOK_SECRET=whsec_xxxxx
PADDLE_PRODUCTION_MONTHLY_PRICE_ID=pri_xxxxx
PADDLE_PRODUCTION_ANNUAL_PRICE_ID=pri_xxxxx

# Backward-compatible production aliases (optional legacy names)
PADDLE_API_KEY=pdl_live_xxxxx
PADDLE_CLIENT_TOKEN=live_xxxxx
PADDLE_WEBHOOK_SECRET=whsec_xxxxx
PADDLE_MONTHLY_PRICE_ID=pri_xxxxx
PADDLE_ANNUAL_PRICE_ID=pri_xxxxx

# Email provider selection
EMAIL_PROVIDER=ses

# Shared sender configuration
EMAIL_FROM="HireFlow <gautam@hireflow.dev>"
REPLY_TO_EMAIL=gautam@hireflow.dev

# SES configuration (used only when EMAIL_PROVIDER=ses)
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=

# SendGrid configuration (used only when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# SMTP configuration (used only when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HireFlow <no-reply@hireflow.dev>"

# Email Verification
EMAIL_VERIFICATION_SUCCESS_URL=http://localhost:5173/verify-email/success

# Company Details
COMPANY_NAME=HireFlow
COMPANY_LOGO_URL=http://localhost:5173/logo.png
SUPPORT_EMAIL=support@hireflow.dev
DEMO_REQUEST_TO_EMAIL=support@hireflow.dev

# Email Unsubscribe
EMAIL_UNSUBSCRIBE_PATH=/api/email-campaigns/unsubscribe

# Paddle Sandbox (used when PADDLE_ENVIRONMENT=sandbox)
PADDLE_SANDBOX_API_BASE_URL=https://sandbox-api.paddle.com
PADDLE_SANDBOX_API_KEY=pdl_sdbx_xxxxx
PADDLE_SANDBOX_CLIENT_TOKEN=test_xxxxx
PADDLE_SANDBOX_WEBHOOK_SECRET=whsec_xxxxx
PADDLE_SANDBOX_MONTHLY_PRICE_ID=pri_xxxxx
PADDLE_SANDBOX_ANNUAL_PRICE_ID=pri_xxxxx


# Disabled-by-default score contract shadow diagnostics
AI_CANONICALIZE_SCORE_FIELDS=false
SCORING_CONTRACT_V1_SHADOW=false
# SCORING_CONTRACT_V1_SHADOW_ALLOWED_USER_IDS=
# SCORING_CONTRACT_V1_SHADOW_ALLOWED_ANALYSIS_IDS=
# SCORING_CONTRACT_V1_SHADOW_SAMPLE_RATE=

# AI score cache (Phase 3A helpers only; disabled by default)
AI_SCORE_CACHE_ENABLED=false
# Optional allowlists for future diagnostics/helpers (comma-separated IDs)
AI_SCORE_CACHE_ALLOWED_USER_IDS=
AI_SCORE_CACHE_ALLOWED_ANALYSIS_IDS=
