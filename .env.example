# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hireflow

# Backend Server
BACKEND_PUBLIC_URL=http://localhost:4000
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

# Paddle Payment Gateway
PADDLE_API_KEY=pdl_live_xxxxx
PADDLE_CLIENT_TOKEN=live_xxxxx
PADDLE_ENVIRONMENT=production
PADDLE_WEBHOOK_SECRET=whsec_xxxxx
PADDLE_MONTHLY_PRICE_ID=pri_xxxxx
PADDLE_ANNUAL_PRICE_ID=pri_xxxxx

# Email Configuration - SendGrid API (Recommended for Railway)
# Get API key from: https://app.sendgrid.com/settings/api_keys
# See SENDGRID_SETUP.md for detailed setup instructions
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SMTP_FROM=noreply@hireflow.dev

# Email Configuration - SMTP (Alternative)
# Works for self-hosted or local development
# For Gmail: https://support.google.com/accounts/answer/185833
# For Mailtrap: https://mailtrap.io/docs/integrations/smtp
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your-mailtrap-user
# SMTP_PASS=your-mailtrap-password
# SMTP_FROM=noreply@hireflow.dev

# Email Verification
EMAIL_VERIFICATION_SUCCESS_URL=http://localhost:5173/verify-email/success

# Company Details
COMPANY_NAME=HireFlow
COMPANY_LOGO_URL=http://localhost:5173/logo.png
SUPPORT_EMAIL=support@hireflow.dev

# Email Unsubscribe
EMAIL_UNSUBSCRIBE_PATH=/api/email-campaigns/unsubscribe
